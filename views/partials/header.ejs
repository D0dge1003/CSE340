<header>
    <div>
        <h1 class="siteName"><a href="/" style="text-decoration:none; color:inherit;">CSE Motors</a></h1>
        <% if (locals.loggedin) { %>
            <a href="/account/" title="Go to Account Management">Welcome <%= locals.accountData.account_firstname %></a>
            <a href="/wishlist" title="View your wishlist">My Wishlist</a>
            <a href="/account/logout" title="Logout from the site">Logout</a>
            <% } else { %>
                <a href="/account/login" title="Go to My Account">My Account</a>
                <% } %>
    </div>
</header>
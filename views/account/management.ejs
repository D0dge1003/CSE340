<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } else { %>
        <h1>Account Management</h1>
        <% } %>

            <%- messages() %>

                <h2>Welcome <%= locals.accountData.account_firstname %>
                </h2>

                <% if (errors) { %>
                    <ul class="notice">
                        <% errors.array().forEach(error=> { %>
                            <li>
                                <%= error.msg %>
                            </li>
                            <% }) %>
                    </ul>
                    <% } %>

                        <div class="account-actions">
                            <p>You are logged in.</p>
                            <p><a href="/account/update/<%= locals.accountData.account_id %>">Update Account
                                    Information</a>
                            </p>
                            <p><a href="/wishlist">My Wishlist</a></p>
                        </div>

                        <% if (locals.accountData.account_type==='Employee' || locals.accountData.account_type==='Admin'
                            ) { %>
                            <div class="inventory-mgmt">
                                <h3>Inventory Management</h3>
                                <p><a href="/inv/">Manage Inventory</a></p>
                            </div>
                            <% } %>
<% if (title) { %>
    <h1>
        <%= title %>
    </h1>
    <% } else { %>
        <h1>My Wishlist</h1>
        <% } %>

            <%- messages() %>

                <% if (wishlistItems.length> 0) { %>
                    <div class="wishlist-grid">
                        <% wishlistItems.forEach(function(item) { %>
                            <div class="wishlist-card">
                                <a href="/inv/detail/<%= item.inv_id %>"
                                    title="View <%= item.inv_make %> <%= item.inv_model %> details">
                                    <img src="<%= item.inv_thumbnail %>"
                                        alt="Image of <%= item.inv_make %> <%= item.inv_model %> on CSE Motors" />
                                </a>
                                <div class="namePrice">
                                    <h3>
                                        <a href="/inv/detail/<%= item.inv_id %>"
                                            title="View <%= item.inv_make %> <%= item.inv_model %> details">
                                            <%= item.inv_make %>
                                                <%= item.inv_model %>
                                        </a>
                                    </h3>
                                    <span class="price">$<%= new Intl.NumberFormat('en-US').format(item.inv_price) %>
                                            </span>

                                    <form action="/wishlist/remove" method="post">
                                        <input type="hidden" name="wishlist_id" value="<%= item.wishlist_id %>">
                                        <button type="submit" class="danger-btn">Remove</button>
                                    </form>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <p>Your wishlist is empty.</p>
                        <% } %>